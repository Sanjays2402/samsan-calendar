    "test:agenda": "node --import tsx --test tests/agenda.test.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "date-fns": "^4.1.0",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rrule": "^2.8.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.3",
    "typescript": "~5.6.3",
    "vite": "^6.0.7"
  }
