{
  "name": "samsan-calendar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview --port 5173 --strictPort",
